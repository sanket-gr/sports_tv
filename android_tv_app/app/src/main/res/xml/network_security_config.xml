<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Permit cleartext HTTP only to the backend server and local testing hosts -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">13.204.129.74</domain>
    </domain-config>

    <!-- Permit cleartext traffic globally to support raw IP backends and HTTP stream URLs -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
